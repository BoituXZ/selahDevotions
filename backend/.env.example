# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google Cloud Vertex AI
GOOGLE_APPLICATION_CREDENTIALS="./service-account.json"
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# Frontend Configuration (for CORS)
FRONTEND_URL=http://localhost:5173

# Optional: Environment Settings
NODE_ENV=development
LOG_LEVEL=info
PORT=3000

# Encryption Configuration (for devotions)
# Generate with: openssl rand -base64 48
# WARNING: Keep this secret safe! Never commit to version control
ENCRYPTION_MASTER_KEY=your-super-secret-master-key-here-use-openssl-rand-base64-48
ENCRYPTION_SALT=selah-encryption-v1
