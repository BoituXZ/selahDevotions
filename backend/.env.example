# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google AI Studio
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Frontend Configuration (for CORS)
FRONTEND_URL=http://localhost:5173

# Optional: Environment Settings
NODE_ENV=development
LOG_LEVEL=info
PORT=3000

# Encryption Configuration (for devotions)
# Generate with: openssl rand -base64 48
# WARNING: Keep this secret safe! Never commit to version control
ENCRYPTION_MASTER_KEY=your-super-secret-master-key-here-use-openssl-rand-base64-48
ENCRYPTION_SALT=selah-encryption-v1
